# ─── Application Under Test ───────────────────────────────────────────────────

# Base URL of the UI being tested (used by page.goto() and for cookie domains)
# Default fallback in src/config/env.ts: https://dummyjson.com
BASE_URL=https://practicesoftwaretesting.com

# Base URL of the API being tested (used by ApiClient).
# Only set this when the API lives on a different domain than the UI,
# e.g. UI=https://practicesoftwaretesting.com and API=https://api.practicesoftwaretesting.com.
# When omitted, it falls back to BASE_URL.
API_BASE_URL=https://api.practicesoftwaretesting.com

# ─── Authentication Credentials ───────────────────────────────────────────────

# Credentials used by auth.setup.ts to generate and cache a session token.
# APP_USER is the login identifier (an email for the Toolshop API).
APP_USER=customer@practicesoftwaretesting.com
APP_PASSWORD=welcome01

# Path of the API login endpoint, relative to API_BASE_URL.
# Default: /users/login (Toolshop API). Override for other targets (e.g. /auth/login).
# AUTH_LOGIN_PATH=/users/login

# localStorage key the front-end SPA reads the JWT from.
# Default: auth-token (Toolshop Angular app).
# AUTH_STORAGE_KEY=auth-token

# ─── Optional / CI Overrides ──────────────────────────────────────────────────

# Number of parallel workers (e.g. 4, or '50%'). Defaults to 100% on CI.
# WORKERS=4

# Set to 'true' to spin up the local dev server before the test run
# RUN_SERVER=true

# Port used by the local dev server (if RUN_SERVER is enabled)
# PORT=3000

# Set to 'true' to force-update all visual snapshots
# UPDATE_SNAPSHOTS=true